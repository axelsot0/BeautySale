# Supabase
SUPABASE_PROJECT_REF=
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres direct (used by supabase CLI for migrations)
SUPABASE_DB_PASSWORD=

# Super admin (Postman-only endpoints)
SUPER_ADMIN_TOKEN=

# Admin allowlist (comma-separated emails con acceso al panel /admin)
ADMIN_EMAILS=

# PayPal
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# PayPal de plataforma (suscripciones)
PLATFORM_PAYPAL_CLIENT_ID=
PLATFORM_PAYPAL_SECRET=
PLATFORM_PAYPAL_MODE=sandbox

# Resend (email confirmaciones)
RESEND_API_KEY=
RESEND_FROM_EMAIL=BeautySale <onboarding@resend.dev>

# Public app URL (para emails y links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
